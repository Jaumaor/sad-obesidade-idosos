# ============================================================================
# Variáveis de Ambiente - SAD
# 
# IMPORTANTE: Este é um arquivo de EXEMPLO.
# Copie este arquivo para .env e preencha com os valores reais:
#   Copy-Item .env.example .env
#
# ⚠️ NUNCA versione o arquivo .env no Git (já está no .gitignore)
# ============================================================================

# ===== AMBIENTE =====
ENVIRONMENT=development  # Opções: development, production

# ===== BANCO DE DADOS =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sad_obesidade
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui  

# ===== MODELO DE ML =====
MODEL_VERSION=1.0.0

# ===== SEGURANÇA =====
# Chave secreta para Flask (caso utilize Flask em vez de Streamlit)
# SECRET_KEY=gere_uma_chave_aleatoria_complexa_aqui

# ===== GEOCODIFICAÇÃO (OPCIONAL) =====
# Caso utilize APIs de geocodificação (Google Maps, OpenCage, etc.)
# GEOCODING_API_KEY=sua_api_key_aqui

# ===== E-MAIL (OPCIONAL - para envio de alertas) =====
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@exemplo.com
# SMTP_PASSWORD=sua_senha_app

# ===== LOGS =====
LOG_LEVEL=INFO  # Opções: DEBUG, INFO, WARNING, ERROR, CRITICAL
